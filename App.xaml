<Application x:Class="CyberAwarenessBot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgDarkBrush"      Color="#0D1117"/>
        <SolidColorBrush x:Key="BgPanelBrush"     Color="#161B22"/>
        <SolidColorBrush x:Key="BgInputBrush"     Color="#1F2937"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#00FF88"/>
        <SolidColorBrush x:Key="AccentBlueBrush"  Color="#00BFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextMutedBrush"   Color="#8B949E"/>
        <SolidColorBrush x:Key="BotBubbleBrush"   Color="#1C2E4A"/>
        <SolidColorBrush x:Key="UserBubbleBrush"  Color="#0A3622"/>
        <SolidColorBrush x:Key="BorderBrush2"     Color="#30363D"/>

        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background" Value="#00FF88"/>
            <Setter Property="Foreground" Value="#0D1117"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00CC6A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#009950"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>