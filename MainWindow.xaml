<Window x:Class="CyberAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberGuard AI — Cybersecurity Awareness Chatbot"
        Height="780" Width="1100"
        MinHeight="600" MinWidth="820"
        Background="{StaticResource BgDarkBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ LEFT SIDEBAR ══════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Header -->
                <Border DockPanel.Dock="Top" Background="#0D1117" Padding="16,18">
                    <StackPanel>
                        <TextBlock Text="⚡ CYBERGUARD AI"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   FontSize="15" FontWeight="Bold"/>
                        <TextBlock Text="Cybersecurity Awareness Bot"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ASCII Art -->
                <Border DockPanel.Dock="Top"
                        Margin="12,12,12,8" Padding="8"
                        Background="#0D1117" CornerRadius="8"
                        BorderBrush="#00FF8833" BorderThickness="1">
                    <TextBlock x:Name="AsciiArtBlock"
                               FontFamily="Consolas" FontSize="9"
                               Foreground="{StaticResource AccentGreenBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" LineHeight="12"/>
                </Border>

                <!-- Voice Button -->
                <Button DockPanel.Dock="Top"
                        x:Name="VoiceGreetingButton"
                        Style="{StaticResource VoiceButton}"
                        Content="🔊  Play Voice greeting"
                        Margin="12,8,12,8"
                        Click="VoiceGreetingButton_Click"/>

                <Separator DockPanel.Dock="Top" Margin="12,8"
                           Background="{StaticResource BorderBrush2}"/>

                <!-- User Memory Panel -->
                <StackPanel DockPanel.Dock="Top" Margin="14,8,14,0">
                    <TextBlock Text="◈  USER PROFILE"
                               Foreground="{StaticResource AccentBlueBrush}"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                    <Border Background="#0D1117" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="MemoryNameBlock"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" TextWrapping="Wrap"/>
                            <TextBlock x:Name="MemoryTopicBlock"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock x:Name="MemoryLevelBlock"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Margin="12,8"
                           Background="{StaticResource BorderBrush2}"/>

                <!-- Quick Topics -->
                <StackPanel DockPanel.Dock="Top" Margin="12,0,12,8">
                    <TextBlock Text="◈  QUICK TOPICS"
                               Foreground="{StaticResource AccentBlueBrush}"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                    <Button Style="{StaticResource CyberButton}" 
                            Content="🔒 Passwords" Tag="passwords"
                            Margin="0,0,0,5" Click="QuickTopic_Click"
                            Background="#1C2E4A" Foreground="{StaticResource AccentGreenBrush}"
                            FontSize="11" Height="32"/>

                    <Button Style="{StaticResource CyberButton}" 
                            Content="🎣 Phishing" Tag="phishing"
                            Margin="0,0,0,5" Click="QuickTopic_Click"
                            Background="#1C2E4A" Foreground="{StaticResource AccentGreenBrush}"
                            FontSize="11" Height="32"/>

                    <Button Style="{StaticResource CyberButton}" 
                            Content="🛡️ Privacy" Tag="privacy"
                            Margin="0,0,0,5" Click="QuickTopic_Click"
                            Background="#1C2E4A" Foreground="{StaticResource AccentGreenBrush}"
                            FontSize="11" Height="32"/>

                    <Button Style="{StaticResource CyberButton}" 
                            Content="🦠 Malware" Tag="malware"
                            Margin="0,0,0,5" Click="QuickTopic_Click"
                            Background="#1C2E4A" Foreground="{StaticResource AccentGreenBrush}"
                            FontSize="11" Height="32"/>

                    <Button Style="{StaticResource CyberButton}" 
                            Content="🔑 2FA" Tag="2fa"
                            Margin="0,0,0,5" Click="QuickTopic_Click"
                            Background="#1C2E4A" Foreground="{StaticResource AccentGreenBrush}"
                            FontSize="11" Height="32"/>

                    <Button Style="{StaticResource CyberButton}" 
                            Content="⚠️ Scam" Tag="scam"
                            Margin="0,0,0,5" Click="QuickTopic_Click"
                            Background="#1C2E4A" Foreground="{StaticResource AccentGreenBrush}"
                            FontSize="11" Height="32"/>

                    <Button Style="{StaticResource CyberButton}" 
                            Content="💰 Ransomware" Tag="ransomware"
                            Margin="0,0,0,5" Click="QuickTopic_Click"
                            Background="#1C2E4A" Foreground="{StaticResource AccentGreenBrush}"
                            FontSize="11" Height="32"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom"
                           Text="v2.0  |  PROG6221  |  Part 2"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            </DockPanel>
        </Border>

        <!-- ══════════════ MAIN CHAT AREA ══════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource BorderBrush2}"
                    BorderThickness="0,0,0,1" Padding="20,0">
                <DockPanel VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#00FF88" Margin="0,0,10,0"/>
                    <TextBlock Text="SECURE CHAT SESSION"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="● CONNECTED"
                               Foreground="#00FF88"
                               FontSize="11" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Sentiment Indicator -->
            <Border Grid.Row="1"
                    x:Name="SentimentBorder"
                    Background="#161B22"
                    BorderBrush="{StaticResource BorderBrush2}"
                    BorderThickness="0,0,0,1" Padding="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SentimentEmoji" Text="😐" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock x:Name="SentimentBlock"
                               Text="Sentiment: Neutral"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Chat ScrollViewer -->
            <ScrollViewer Grid.Row="2"
                          x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource BgDarkBrush}"
                          Padding="16,12">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

            <!-- Input Bar -->
            <Border Grid.Row="3"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource BorderBrush2}"
                    BorderThickness="0,1,0,0" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="UserInputBox"
                             Style="{StaticResource InputBox}"
                             MinHeight="44"
                             VerticalContentAlignment="Center"
                             KeyDown="UserInputBox_KeyDown"
                             Margin="0,0,10,0"/>

                    <Button Grid.Column="1"
                            Style="{StaticResource CyberButton}"
                            Content="SEND ▶"
                            Height="44"
                            Click="SendButton_Click"
                            Margin="0,0,10,0"/>

                    <Button Grid.Column="2"
                            x:Name="ClearChatButton"
                            Style="{StaticResource CyberButton}"
                            Content="🗑️"
                            Width="50"
                            Height="44"
                            Background="#DC2626"
                            Click="ClearChatButton_Click"
                            ToolTip="Clear conversation"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>