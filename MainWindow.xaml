<Window x:Class="CyberAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CyberGuard AI"
        Height="820"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111827"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="BotBubbleBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="UserBubbleBrush" Color="#0B3B2E"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#22C55E"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#38BDF8"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#334155"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#334155"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.2*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Chat Panel -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <!-- New row for status bar -->
            </Grid.RowDefinitions>

            <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="CyberGuard AI"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"/>
                    <TextBlock x:Name="SentimentIndicatorText"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Sentiment: 😐 Neutral"/>
                    <TextBlock x:Name="AsciiArtBlock"
                               Margin="0,10,0,0"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="{StaticResource AccentGreenBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="12" Padding="10">
                <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ChatPanel"/>
                </ScrollViewer>
            </Border>

            <!-- Input Row -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInputTextBox"
                         Height="42"
                         VerticalContentAlignment="Center"
                         KeyDown="UserInputTextBoxKeyDown"/>

                <Button Grid.Column="1"
                        Width="100"
                        Height="42"
                        Content="Send"
                        Click="SendButtonClick"/>
            </Grid>

            <!-- Status Bar -->
            <TextBlock x:Name="StatusBar" Grid.Row="3"
                       Foreground="#FFD700" FontSize="12" 
                       Margin="4,5,4,0" VerticalAlignment="Center"
                       Text=""/>
        </Grid>

        <!-- Right Panel: Tabs -->
        <TabControl Grid.Column="1" Background="{StaticResource PanelBackgroundBrush}" Foreground="White">
            <TabItem Header="Memory">
                <Border Background="{StaticResource PanelBackgroundBrush}" Padding="10">
                    <StackPanel>
                        <TextBlock Text="User Memory" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource AccentBlueBrush}"/>
                        <TextBlock x:Name="MemoryNameText" Margin="0,4" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="MemoryTopicText" Margin="0,4" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="MemoryLevelText" Margin="0,4" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Tasks">
                <Grid Background="{StaticResource PanelBackgroundBrush}" Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Cybersecurity Tasks" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource AccentBlueBrush}"/>

                    <StackPanel Grid.Row="1">
                        <TextBox x:Name="TaskTitleTextBox" ToolTip="Task title"/>
                        <TextBox x:Name="TaskDescriptionTextBox" ToolTip="Description (optional)"/>
                        <TextBox x:Name="TaskReminderTextBox" ToolTip="Reminder e.g. 2026-06-30 14:00 (optional)"/>
                        <WrapPanel>
                            <Button Content="Add Task" Click="AddTaskButtonClick" Background="#2563EB"/>
                            <Button Content="Refresh" Click="RefreshTasksButtonClick" Background="#2563EB"/>
                        </WrapPanel>
                    </StackPanel>

                    <ListBox x:Name="TasksListBox" Grid.Row="2" Margin="0,10,0,10" DisplayMemberPath="ToString"/>

                    <WrapPanel Grid.Row="3">
                        <Button Content="Mark Completed" Click="CompleteTaskButtonClick" Background="#22C55E"/>
                        <Button Content="Delete Task" Background="#EF4444" Click="DeleteTaskButtonClick"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Quiz">
                <Grid Background="#111827" Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="🧠 Cybersecurity Mini-Quiz" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#38BDF8" 
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="QuizQuestionText"
                               Grid.Row="1"
                               Margin="0,10,0,15"
                               TextWrapping="Wrap"
                               FontSize="16"
                               Foreground="#E5E7EB"
                               Text="📝 Click 'Start Quiz' to begin the cybersecurity quiz!"/>

                    <StackPanel Grid.Row="2" Margin="0,5,0,10">
                        <RadioButton x:Name="Option1Radio" 
                                     GroupName="QuizOptions" 
                                     Margin="0,5" 
                                     Foreground="#E5E7EB"
                                     FontSize="14"/>
                        <RadioButton x:Name="Option2Radio" 
                                     GroupName="QuizOptions" 
                                     Margin="0,5" 
                                     Foreground="#E5E7EB"
                                     FontSize="14"/>
                        <RadioButton x:Name="Option3Radio" 
                                     GroupName="QuizOptions" 
                                     Margin="0,5" 
                                     Foreground="#E5E7EB"
                                     FontSize="14"/>
                        <RadioButton x:Name="Option4Radio" 
                                     GroupName="QuizOptions" 
                                     Margin="0,5" 
                                     Foreground="#E5E7EB"
                                     FontSize="14"/>
                        <TextBlock x:Name="QuizFeedbackText"
                                   Margin="0,15,0,0"
                                   Foreground="#22C55E"
                                   TextWrapping="Wrap"
                                   FontSize="14"/>
                    </StackPanel>

                    <WrapPanel Grid.Row="3" Margin="0,10,0,0">
                        <Button Content="▶ Start Quiz" 
                                Click="StartQuizButtonClick" 
                                Background="#2563EB" 
                                Foreground="White"
                                Padding="15,8"
                                Margin="5"/>
                        <Button Content="✅ Submit Answer" 
                                Click="SubmitQuizAnswerButtonClick" 
                                Background="#2563EB" 
                                Foreground="White"
                                Padding="15,8"
                                Margin="5"/>
                        <Button Content="➡ Next Question" 
                                Click="NextQuizQuestionButtonClick" 
                                Background="#2563EB" 
                                Foreground="White"
                                Padding="15,8"
                                Margin="5"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Log">
                <Grid Background="{StaticResource PanelBackgroundBrush}" Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Recent Activity" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}"/>

                    <ListBox x:Name="ActivityLogListBox"
                             Grid.Row="1"
                             Margin="0,10,0,10"
                             DisplayMemberPath="DisplayText"/>

                    <WrapPanel Grid.Row="2">
                        <Button Content="Refresh Log" Click="RefreshLogButtonClick" Background="#2563EB"/>
                        <Button Content="Show More" Click="ShowMoreLogButtonClick" Background="#2563EB"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>